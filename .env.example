# Database
DATABASE_URL=postgres://sybilshield:sybilshield@localhost:5432/sybilshield

# Redis
REDIS_URL=redis://localhost:6379

# Alchemy
ALCHEMY_API_KEY=your_alchemy_key_here
ALCHEMY_TIER=scale
ALCHEMY_RATE_LIMIT_RPS=10

# Dune Sim (balances)
DUNE_API_KEY=your_dune_sim_key_here

# Etherscan (contract labels)
ETHERSCAN_API_KEY=your_etherscan_key_here

# Self-hosted node (Phase 3+, overrides Alchemy when set)
SELF_HOSTED_NODE_URL=

# Stripe (billing) — DORMANT under the free public-good model. Leave empty;
# the billing routes 503 when unset. Kept for a possible future pivot.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# API
API_PORT=3001
API_HOST=0.0.0.0
JWT_SECRET=change_me_in_production_to_a_long_random_string

# ML service (Python)
ML_SERVICE_URL=http://localhost:8001
ML_MODEL_DIR=./apps/ml/sybilshield/data/models

# Storage (S3-compatible for CSV/results)
S3_ENDPOINT=
S3_BUCKET=sybilshield
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Feature flags
USE_MOCK_PROVIDERS=true
# ─── Production flip: switch to real on-chain ───
# 1. Get key from https://dashboard.alchemy.com (Scale tier ~$199/mo)
# 2. Set ALCHEMY_API_KEY above + flip USE_MOCK_PROVIDERS=false
# 3. docker compose up -d --build api worker ml

# ─── Model deployment ───
ML_MODEL_PATH=/app/apps/ml/sybilshield/data/models/current.pkl
ML_MODEL_VERSION=v0.2.0

# ─── Atlos crypto checkout — DORMANT under the free public-good model ───
# Leave empty. /v1/billing/checkout returns 503 crypto_checkout_not_configured
# when unset. Kept for a possible future pivot.
ATLOS_MERCHANT_ID=
ATLOS_API_SECRET=

# ─── Public URLs (used in checkout success/cancel + webhook callbacks) ───
API_PUBLIC_URL=http://localhost:3001
WEB_PUBLIC_URL=http://localhost:3000

# ─── Stripe price IDs — DORMANT (free public-good model). Leave empty. ───
STRIPE_PRICE_DEVELOPER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=
